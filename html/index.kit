<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="Arkadiusz Femin">
    <meta name="keywords"
        content="optyk, salon optyczny, okulary korekcyjne, okulary przeciwsłoneczne, dobór okularów, okulista i optyk, badanie wzroku, optometrysta, szkła progresywne, oprawki okularowe">
    <meta name="description"
        content="Profesjonalny optyk w Warszawie. Badanie wzroku, okulary korekcyjne, przeciwsłoneczne i szkła progresywne. Szeroki wybór oprawek i fachowe doradztwo.">
    <title>OptyNova – Przejrzysta Wizja Twojego Stylu</title>
    <!-- @include 'favicon.kit' -->
    <!-- @include 'styles.kit' -->
</head>

<body>
    <!-- @include 'nav.kit' -->

    <header class="header">
        <div class="wrapper">
            <div class="header__content">
                <p class="header__info">Luxury Eyewear</p>
                <h1 class="header__title">optynova<br><span
                        class="header__title-word--highlighted">precyzja</span><br>wizja
                </h1>
                <p class="header__text">Najwyższa precyzja badania wzroku i selekcja oprawek od światowych projektantów.
                    Odkryj nowy wymiar ostrości widzenia.</p>
                <div class="header__buttons">
                    <a href="/optynova/#kontakt" class="button button--header">umów badanie</a>
                    <a href="/optynova/#o-nas" class="button button--secondary">o nas</a>
                </div>
            </div>
            <div class="header__image-box">
                <img class="header__image" src="./dist/img/hero.jpeg"
                    alt="Pani o krótkich włosach w okularach i marynarce w granatowym kolorze">
                <div class="header__badge">
                    <p class="header__badge-text">starannie wyselekcjonowana jakość</p>
                </div>
            </div>
            <span class="header__background-text">nova</span>
        </div>
    </header>

    <main class="main">
        <section class="section section--color">
            <div class="wrapper">
                <h2 class="section__title">Dlaczego My</h2>
                <div class="section__title-underline"></div>
                <div class="why-us__list ">
                    <div class="why-us__item" data-reveal data-delay="1">
                        <div class="why-us__icon" aria-hidden="true">
                            <span class="material-symbols-outlined">
                                workspace_premium</span>
                        </div>
                        <h3 class="why-us__item-title">Doświadczenie</h3>
                    </div>
                    <div class="why-us__item" data-reveal data-delay="1">
                        <div class="why-us__icon" aria-hidden="true">
                            <span class="material-symbols-outlined">
                                biotech</span>
                        </div>
                        <h3 class="why-us__item-title">Nowoczesny sprzęt</h3>
                    </div>
                    <div class="why-us__item" data-reveal data-delay="1">
                        <div class="why-us__icon" aria-hidden="true">
                            <span class="material-symbols-outlined">
                                local_shipping</span>
                        </div>
                        <h3 class="why-us__item-title">Szybka realizacja</h3>
                    </div>
                    <div class="why-us__item" data-reveal data-delay="1">
                        <div class="why-us__icon" aria-hidden="true">
                            <span class="material-symbols-outlined">
                                support_agent</span>
                        </div>
                        <h3 class="why-us__item-title">Indywidualne doradztwo</h3>
                    </div>
                    <div class="why-us__item" data-reveal data-delay="1">
                        <div class="why-us__icon" aria-hidden="true">
                            <span class="material-symbols-outlined">
                                eyeglasses
                            </span>
                        </div>
                        <h3 class="why-us__item-title">Szeroki wybór oprawek</h3>
                    </div>
                </div>
            </div>

        </section>
        <section id="o-nas" class="section">
            <div class="wrapper">
                <div class="about-us"><img class="about-us__image about-us__image--desktop"
                        src="./dist/img/about_us.jpeg" alt="Wnętrze salonu Optynova">
                    <div class="about-us__texts-box">
                        <h2 class="section__title section__title--variant">O Nas</h2>
                        <div class="section__title-underline section__title-underline--left"></div>

                        <div class="about-us__content">
                            <p class="about-us__paragraph">
                                OptyNova to miejsce, gdzie innowacyjna technologia spotyka się z wieloletnią tradycją
                                optyczną. Od ponad dekady z pasją i zaangażowaniem dbamy o wzrok naszych klientów
                                oferując
                                im rozwiązania na najwyższym światowym poziomie.
                            </p>
                            <img class="about-us__image about-us__image--mobile" src="./dist/img/about_us.jpeg"
                                alt="Wnętrze salonu Optynova">
                            <p class="about-us__paragraph">
                                Nasz zespół składa się z wykwalifikowanych optometrystów i stylistów, którzy wierzą, że
                                okulary to nie tylko narzędzie do korekcji wzroku, ale również kluczowy element
                                osobistego
                                stylu i wizerunku. W naszym salonie znajdziesz starannie wyselekcjonowane kolekcje
                                oprawek
                                od najbardziej cenionych domów mody i niezależnych projektantów.
                            </p>
                            <p class="about-us__paragraph">
                                Jesteśmy dumni z naszego podejścia do klienta, które opiera się na indywidualnej
                                analizie
                                potrzeb, precyzyjnych badaniach diagnostycznych oraz profesjonalnym doradztwie. Naszym
                                celem
                                jest zapewnienie Ci doskonałego widzenia i komfortu na co dzień, przy jednoczesnym
                                podkreśleniu Twojej unikalnej osobowości.
                            </p>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section id="uslugi" class="section section--color">
            <div class="wrapper">
                <h2 class="section__title">Nasze Usługi</h2>
                <div class="section__title-underline"></div>
                <div class="services">
                    <div class="card service-card">
                        <div class="service-card__icon">
                            <p class="material-symbols-outlined">visibility</p>
                        </div>
                        <h3 class="service-card__title">Profesjonalne Badanie Wzroku</h3>
                        <p class="service-card__description">Zaawansowana diagnostyka optometryczna z wykorzystaniem
                            najnowszych technologii obrazowania oka.</p>
                    </div>
                    <div class="card service-card">
                        <div class="service-card__icon">
                            <p class="material-symbols-outlined">face</p>
                        </div>
                        <h3 class="service-card__title">Indywidualny Dobór Oprawek</h3>
                        <p class="service-card__description">Osobiste doradztwo stylistyczne, dopasowanie kształtu i
                            materiału
                            do fizjonomii twarzy
                            klienta.</p>
                    </div>
                    <div class="card service-card">
                        <div class="service-card__icon">
                            <p class="material-symbols-outlined">verified</p>
                        </div>
                        <h3 class="service-card__title">Serwis i Gwarancja</h3>
                        <p class="service-card__description">Kompleksowa opieka posprzedażowa, czyszczenie
                            ultradźwiękowe i
                            precyzyjna regulacja
                            zauszników.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section--hero">
            <div class="wrapper">
                <p class="cta__title">Zadbaj o swój wzrok</p>
                <p class="cta__description">Umów się na profesjonalne badanie wzroku i dołącz do grona naszych
                    zadowolonych
                    klientów.</p>
            </div>
        </section>

        <section class="section">
            <div class="wrapper">
                <h2 class="section__title">Jak Wygląda Wizyta?</h2>
                <div class="section__title-underline"></div>
                <div class="process__list">
                    <div class="process__line"></div>
                    <div class="process__item">
                        <div class="process__item-number">
                            <p>1</p>
                        </div>
                        <h3 class="process__item-title">Rezerwacja terminu</h3>
                        <p class="process__item-description">Wybierz dogodny dla siebie czas wizyty w naszym salonie.
                        </p>
                    </div>
                    <div class="process__item">
                        <div class="process__item-number">
                            <p>2</p>
                        </div>
                        <h3 class="process__item-title">Badanie wzroku</h3>
                        <p class="process__item-description">Szczegółowa diagnostyka przy użyciu najnowocześniejszego
                            sprzętu.</p>
                    </div>
                    <div class="process__item">
                        <div class="process__item-number">
                            <p>3</p>
                        </div>
                        <h3 class="process__item-title">Dobór oprawek</h3>
                        <p class="process__item-description">Konsultacja ze stylistą i wybór idealnych oprawek.</p>
                    </div>
                    <div class="process__item">
                        <div class="process__item-number">
                            <p>4</p>
                        </div>
                        <h3 class="process__item-title">Odbiór okularów</h3>
                        <p class="process__item-description">Precyzyjne dopasowanie gotowych okularów do Twojej twarzy.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <section id="cennik" class="section section--color">
            <div class="wrapper">
                <h2 class="section__title">Cennik</h2>
                <div class="section__title-underline"></div>

                <div class="prices">
                    <div class="price">
                        <div class="price__info">
                            <h3 class="price__name">Podstawowe badanie wzroku</h3>
                            <p class="price__description">Standardowa kontrola ostrości wzroku i doboru okularów.</p>
                        </div>
                        <p class="price__value">150 PLN</p>
                    </div>
                    <div class="price">
                        <div class="price__info">
                            <h3 class="price__name">Pełne badanie optometryczne</h3>
                            <p class="price__description">Rozszerzone badanie obejmujące ocenę widzenia obuocznego.</p>
                        </div>
                        <p class="price__value">250 PLN</p>
                    </div>
                    <div class="price">
                        <div class="price__info">
                            <h3 class="price__name">Aplikacja soczewek kontaktowych</h3>
                            <p class="price__description">Dobór pierwszych soczewek oraz nauka zakładania i zdejmowania.
                            </p>
                        </div>
                        <p class="price__value">200 PLN</p>
                    </div>
                </div>
            </div>
        </section>
        <section class="section">
            <div class="wrapper">
                <h2 class="section__title">Nasze Marki</h2>
                <div class="section__title-underline"></div>
                <div class="brands__items">
                    <p class="brands__item">Ray-Ban</p>
                    <p class="brands__item brands__item--oakley">Oakley</p>
                    <p class="brands__item brands__item--gucci">Gucci</p>
                    <p class="brands__item brands__item--prada">Prada</p>
                    <p class="brands__item brands__item--tom-ford">Tom Ford</p>
                </div>

            </div>
        </section>

        <section class="section section--color">
            <div class="wrapper">
                <h2 class="section__title">Opinie</h2>
                <div class="section__title-underline"></div>
                <div class="testimonials">
                    <div class="card testimonial">
                        <div class="testimonial__stars">
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                        </div>
                        <p class="testimonial__text">"Pełen profesjonalizm i niesamowite podejście do klienta.
                            Dobór oprawek to była czysta
                            przyjemność!"</p>
                        <p class="testimonial__author">Anna K.</p>
                    </div>
                    <div class="card testimonial">
                        <div class="testimonial__stars">
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                        </div>
                        <p class="testimonial__text">"Najdokładniejsze badanie wzroku, jakie kiedykolwiek miałem.
                            Nowe okulary są idealnie dobrane."</p>
                        <p class="testimonial__author">Marek T.</p>
                    </div>
                    <div class="card testimonial">
                        <div class="testimonial__stars">
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
                        </div>
                        <p class="testimonial__text">"Piękny salon i ogromny wybór marek premium. Zdecydowanie
                            polecam każdemu, kto szuka jakości."</p>
                        <p class="testimonial__author">Julia S.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="kontakt" class="section">
            <div class="wrapper">
                <h2 class="section__title">Kontakt</h2>
                <div class="section__title-underline"></div>

                <div class="contact__inner">
                    <address class="contact__info">
                        <div class="contact__item">
                            <span class="material-symbols-outlined">location_on</span>
                            <div>
                                <h3 class="contact__label">Nasz Salon</h3>
                                <p class="contact__value">ul. Optyczna 372,<br />00-001 Warszawa</p>
                            </div>
                        </div>
                        <div class="contact__item">
                            <span class="material-symbols-outlined">call</span>
                            <div>
                                <h3 class="contact__label">Zadzwoń do nas</h3>
                                <p class="contact__value"><a href="tel:+48123456789">+48 123 456 789</a></p>
                            </div>
                        </div>
                        <div class="contact__item">
                            <span class="material-symbols-outlined">mail</span>
                            <div>
                                <h3 class="contact__label">Napisz do nas</h3>
                                <p class="contact__value"><a href="mailto:kontakt@optynova.pl">kontakt@optynova.pl</a>
                                </p>
                            </div>
                        </div>
                        <div class="contact__item">
                            <span class="material-symbols-outlined">schedule</span>
                            <div>
                                <h3 class="contact__label">Godziny otwarcia</h3>
                                <p class="contact__value">Pon–Pt: 9:00–19:00<br />Sob: 10:00–15:00</p>
                            </div>
                        </div>
                    </address>

                    <div class="contact__map">
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d394.68232316697373!2d21.133499631757168!3d52.24000188073739!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471ed20d07f54799%3A0xe2056c5ec22d42ba!2sOptyczna%2C%20Warszawa!5e0!3m2!1spl!2spl!4v1778936132716!5m2!1spl!2spl"
                            width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>

            </div>
        </section>

    </main>

    <!-- @include 'footer.kit' -->
    <!-- @include 'script.kit' -->

</body>

</html>